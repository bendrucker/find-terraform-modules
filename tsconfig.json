{
  "compilerOptions": {
    "target": "es2022",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "types": ["node"]
  },
  "exclude": ["node_modules", "dist"]
}
